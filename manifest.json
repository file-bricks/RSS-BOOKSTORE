{
  "manifest_version": 3,
  "name": "RSS-BOOKSTORE",
  "version": "1.0.0",
  "description": "Erweiterte RSS/Atom-Extension mit Bookmark-Export und Native Messaging Sync.",
  "permissions": [
    "bookmarks",
    "storage",
    "alarms",
    "notifications",
    "nativeMessaging",
    "scripting",
    "activeTab"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "action": {
    "default_popup": "ui/popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "options_page": "ui/options.html",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
